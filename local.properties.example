# Copy this file to local.properties and fill in your local values.
# local.properties is ignored by Git.

# Android SDK path. Android Studio usually creates this automatically.
sdk.dir=/path/to/Android/sdk

# Required for manual map picking.
GOOGLE_MAPS_API_KEY=your_google_maps_android_key

# Required for remote anomaly and earthquake upload/read.
MONGODB_CONNECTION_STRING=your_mongodb_atlas_connection_string
ATLAS_DATABASE=bananaginger
ATLAS_ANOMALY_COLLECTION=anomalies
ATLAS_EARTHQUAKE_COLLECTION=earthquakes
